diff --git a/ArduPlane/sitl_nsu.cpp b/ArduPlane/sitl_nsu.cpp
new file mode 100644
index 0000000000..9339229391
--- /dev/null
+++ b/ArduPlane/sitl_nsu.cpp
@@ -0,0 +1,59 @@
+#include "Plane.h"
+
+#if CONFIG_HAL_BOARD == HAL_BOARD_SITL
+
+#include <SITL/SITL.h>
+
+// Feed the simulated navigation system directly into EKF3. This deliberately
+// bypasses GPS, VisualOdom and every MAVLink navigation-message handler.
+void Plane::update_sitl_nsu()
+{
+    const auto *sitl = AP::sitl();
+    if (sitl == nullptr || sitl->state.home.is_zero()) {
+        return;
+    }
+
+    const Location &origin = sitl->state.home;
+    Location ekf_origin;
+    if (!ahrs.get_origin(ekf_origin)) {
+        IGNORE_RETURN(ahrs.set_origin(origin));
+    }
+    if (!ahrs.home_is_set() && set_home_persistently(origin)) {
+        next_WP_loc = prev_WP_loc = origin;
+    }
+
+    // SIM_VICON_FAIL is reused only as a deterministic NSU failure switch for
+    // the pre-arm regression test. No Vicon transport is instantiated.
+    if (sitl->vicon_fail.get() != 0) {
+        return;
+    }
+
+    const auto &state = sitl->state;
+    if (!isfinite(state.latitude) || !isfinite(state.longitude) ||
+        !isfinite(state.altitude) || !isfinite(state.speedN) ||
+        !isfinite(state.speedE) || !isfinite(state.speedD) ||
+        state.quaternion.is_zero()) {
+        return;
+    }
+
+    const Location location(
+        int32_t(state.latitude * 1.0e7),
+        int32_t(state.longitude * 1.0e7),
+        int32_t(state.altitude * 100.0),
+        Location::AltFrame::ABSOLUTE);
+    const Vector3f position_ned = origin.get_distance_NED(location);
+    const Vector3f velocity_ned(state.speedN, state.speedE, state.speedD);
+    const uint32_t now_ms = AP_HAL::millis();
+
+    ahrs.writeExtNavData(
+        position_ned,
+        state.quaternion,
+        0.1f,
+        radians(5.0f),
+        now_ms,
+        0,
+        0);
+    ahrs.writeExtNavVelData(velocity_ned, 0.1f, now_ms, 0);
+}
+
+#endif  // CONFIG_HAL_BOARD == HAL_BOARD_SITL
diff --git a/Tools/autotest/default_params/plane-sitl-nsu-no-gps.parm b/Tools/autotest/default_params/plane-sitl-nsu-no-gps.parm
