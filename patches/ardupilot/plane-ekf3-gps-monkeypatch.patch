+uint32_t NavEKF3::gps_monkeypatch_next(uint32_t &state)
+{
+    if (state == 0) {
+        state = 0x9E3779B9U;
+    }
+    state ^= state << 13;
+    state ^= state >> 17;
+    state ^= state << 5;
+    return state;
+}
+
+float NavEKF3::gps_monkeypatch_unit_random(uint32_t &state)
+{
+    return (gps_monkeypatch_next(state) >> 8) * (1.0f / 16777216.0f);
+}
+
+bool NavEKF3::gps_monkeypatch_target(Location &target) const
+{
+    if (AP::fwversion().vehicle_type != APM_BUILD_ArduPlane) {
+        return false;
+    }
+
+    const auto type = static_cast<GPSMonkeyPatchType>(int8_t(_mp_type.get()));
+    if (type == GPSMonkeyPatchType::Disabled) {
+        return false;
+    }
+
+    const float lat_deg = _mp_lat.get();
+    const float lng_deg = _mp_lng.get();
+    const float alt_m = _mp_alt_m.get();
+    if (!isfinite(lat_deg) || !isfinite(lng_deg) || !isfinite(alt_m) ||
+        fabsF(alt_m) > LOCATION_ALT_MAX_M) {
+        return false;
+    }
+
+    target = Location(int32_t(lat_deg * 1.0e7f),
+                      int32_t(lng_deg * 1.0e7f),
+                      int32_t(alt_m * 100.0f),
+                      Location::AltFrame::ABSOLUTE);
+    if (!target.check_latlng() || (target.lat == 0 && target.lng == 0)) {
+        return false;
+    }
+
+    if (type == GPSMonkeyPatchType::Fixed) {
+        return true;
+    }
+
+    if (type != GPSMonkeyPatchType::Random) {
+        return false;
+    }
+
+    const float radius_min_m = _mp_radius_min_m.get();
+    const float radius_max_m = _mp_radius_max_m.get();
+    if (!isfinite(radius_min_m) || !isfinite(radius_max_m) ||
+        is_negative(radius_min_m) || is_negative(radius_max_m) ||
+        radius_min_m > radius_max_m) {
+        return false;
+    }
+
+    if (is_zero(radius_max_m)) {
+        return true;
+    }
+
+    uint32_t state = uint32_t(_mp_seed.get());
+    const float radius_sq = sq(radius_min_m) +
+        gps_monkeypatch_unit_random(state) * (sq(radius_max_m) - sq(radius_min_m));
+    const float radius_m = sqrtF(radius_sq);
+    const float bearing_rad = (2.0f * M_PI) * gps_monkeypatch_unit_random(state);
+    target.offset(cosF(bearing_rad) * radius_m, sinF(bearing_rad) * radius_m);
+    return target.check_latlng();
+}
+
+bool NavEKF3::apply_gps_monkeypatch(Location &loc)
+{
+    Location fake_origin;
+    if (!gps_monkeypatch_target(fake_origin)) {
+        _mp_origin_valid = false;
+        return false;
+    }
+
+    if (!_mp_origin_valid || !_mp_fake_origin.same_loc_as(fake_origin)) {
+        _mp_raw_origin = loc;
+        _mp_fake_origin = fake_origin;
+        _mp_origin_valid = true;
+    }
+
+    const Vector2p offset_ne = _mp_raw_origin.get_distance_NE_postype(loc);
+    const int32_t alt_delta_cm = loc.alt - _mp_raw_origin.alt;
+    loc = _mp_fake_origin;
+    loc.offset(offset_ne.x, offset_ne.y);
+    loc.set_alt_cm(_mp_fake_origin.alt + alt_delta_cm, Location::AltFrame::ABSOLUTE);
+    return true;
+}
+
 
